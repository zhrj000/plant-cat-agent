# DeepSeek API配置示例
# 复制此文件为 .env 并填入你的真实API密钥

# DeepSeek API密钥（必填）
DEEPSEEK_API_KEY=your-api-key-here

# DeepSeek模型（可选，默认为deepseek-chat）
DEEPSEEK_MODEL=deepseek-chat

# DeepSeek API地址（可选，默认为https://api.deepseek.com）
DEEPSEEK_BASE_URL=https://api.deepseek.com

# OpenAI API配置（可选）
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-3.5-turbo

# Azure OpenAI配置（可选）
# AZURE_API_KEY=...
# AZURE_ENDPOINT=...
# AZURE_DEPLOYMENT=...
